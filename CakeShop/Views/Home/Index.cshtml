@model IEnumerable<CakeShop.Models.Cake>
@{
    ViewData["Title"] = "首頁 - 蛋糕列表";
}

<div class="text-center mb-4">
    <h1 class="display-4">歡迎來到美味蛋糕網</h1>
    <p>請先登入後方可訂購商品，訂購完成系統將自動發送確認信給您。</p>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var cake in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-primary fw-bold">@cake.Name</h5>
                    <p class="card-text">@cake.Description</p>
                    <h6 class="card-subtitle mb-2 text-danger">NT$ @cake.Price</h6>
                </div>
                <div class="card-footer bg-white border-top-0">
                    @* 訂購表單，會將資料送往 OrdersController 的 Create Action *@
                    <form asp-controller="Orders" asp-action="Create" method="post" class="d-flex align-items-center">
                        <input type="hidden" name="cakeId" value="@cake.Id" />
                        <label class="me-2 mb-0">數量：</label>
                        <input type="number" name="quantity" value="1" min="1" max="10" class="form-control form-control-sm w-25 me-2" required />

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button type="submit" class="btn btn-primary btn-sm w-100">訂購</button>
                        }
                        else
                        {
                            <a href="/Identity/Account/Login" class="btn btn-secondary btn-sm w-100">請先登入</a>
                        }
                    </form>
                </div>
            </div>
        </div>
    }
</div>