@model IEnumerable<CakeShop.Models.Order>
@{
    ViewData["Title"] = "我的訂單";
}

<h2 class="mb-4">我的訂單紀錄</h2>

@if (!Model.Any())
{
<div class="alert alert-info">您目前還沒有任何訂單喔！去<a asp-controller="Home" asp-action="Index">首頁</a>逛逛吧。</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>訂購時間</th>
                    <th>蛋糕名稱</th>
                    <th>數量</th>
                    <th>總價</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@order.Cake.Name</td>
                        <td>@order.Quantity</td>
                        <td class="text-danger fw-bold">NT$ @order.TotalPrice</td>
                        <td>
                            @* 刪除訂單表單 *@
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">取消訂單</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
